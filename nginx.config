events {}

http {
    upstream backend {
        server 4sight-container:8000;
    }

    server {
        listen 80;

        location /4sight/ {
            proxy_pass http://backend/4sight/;

            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Scheme $scheme;
        }
    }
}